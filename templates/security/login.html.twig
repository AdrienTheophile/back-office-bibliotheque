{% extends 'base.html.twig' %}

{% block title %}Connexion - Administration
{% endblock %}

{% block stylesheets %}
	{# Intégration de Bootstrap via CDN pour cette page autonome #}
	<link
	href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
	{# Intégration de FontAwesome pour l'icône #}
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
	<style>
		body {
			background-color: #f8f9fa; /* Fond clair */
		}
		.login-card {
			border-radius: 1rem;
			box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
			border: none;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="container d-flex align-items-center justify-content-center min-vh-100">
		<div class="col-12 col-md-8 col-lg-5">
			<div class="card login-card p-4 p-md-5">
				<div class="text-center mb-4">
					<i class="fa fa-user-lock fa-3x text-primary mb-3"></i>
					<h1 class="h3 mb-3 fw-bold">Espace Administration</h1>
					<p class="text-muted">Veuillez vous connecter pour accéder au tableau de bord de la bibliothèque.</p>
				</div>

				<form method="post">
					{% if error %}
						<div class="alert alert-danger rounded-3">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
					{% endif %}

					{% if app.user %}
						<div class="alert alert-info">
							Connecté en tant que
							{{ app.user.userIdentifier }}
							<br>
							<a href="{{ logout_path() }}" class="alert-link">Déconnexion</a>
						</div>
					{% endif %}

					<div class="form-floating mb-3">
						<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control rounded-3" placeholder="name@example.com" autocomplete="email" required autofocus>
						<label for="username">Adresse Email</label>
					</div>

					<div class="form-floating mb-4">
						<input type="password" name="_password" id="password" class="form-control rounded-3" placeholder="Mot de passe" autocomplete="current-password" required>
						<label for="password">Mot de passe</label>
					</div>

					<input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

					<button class="btn btn-primary btn-lg w-100 rounded-pill fw-bold" type="submit">
						<i class="fa fa-sign-in-alt me-2"></i>Se connecter
					</button>
				</form>
			</div>
		</div>
	</div>
{% endblock %}
