{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Tableau de bord - Bibliothèque
{% endblock %}

{% block content_header %}
	<h1 class="mb-4">
		<i class="fa fa-tachometer-alt me-2 text-primary"></i>Tableau de bord
	</h1>
{% endblock %}

{% block main %}
	{# Définition de styles CSS personnalisés rapides pour les survols (Hover) #}
	<style>
		.dashboard-card {
			transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
		}
		.dashboard-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
			}/* Touche sombre pour EasyAdmin (qui gère le dark mode nativement) */:root[data-theme="dark"] .dashboard-card
			{
				background-color: #2b3035 !important;
			}
	</style>

	<div class="container-fluid pe-0">
		<div
			class="row g-4">

			{# Adhérents #}
			<div class="col-sm-6 col-lg-4">
				<div class="card dashboard-card bg-body text-body shadow-sm border-0 border-start border-4 border-primary h-100">
					<div class="card-body text-center p-4">
						<i class="fa fa-users fa-3x text-primary mb-3"></i>
						<h2 class="display-5 fw-bold mb-0 text-primary">{{ nbAdherents }}</h2>
						<p class="text-muted mt-2 fw-semibold mb-0">Adhérents inscrits</p>
					</div>
				</div>
			</div>

			{# Auteurs #}
			<div class="col-sm-6 col-lg-4">
				<div class="card dashboard-card bg-body text-body shadow-sm border-0 border-start border-4 border-info h-100">
					<div class="card-body text-center p-4">
						<i class="fa fa-pen-fancy fa-3x text-info mb-3"></i>
						<h2 class="display-5 fw-bold mb-0 text-info">{{ nbAuteurs }}</h2>
						<p class="text-muted mt-2 fw-semibold mb-0">Auteurs enregistrés</p>
					</div>
				</div>
			</div>

			{# Catégories #}
			<div class="col-sm-6 col-lg-4">
				<div class="card dashboard-card bg-body text-body shadow-sm border-0 border-start border-4 border-success h-100">
					<div class="card-body text-center p-4">
						<i class="fa fa-tags fa-3x text-success mb-3"></i>
						<h2 class="display-5 fw-bold mb-0 text-success">{{ nbCategories }}</h2>
						<p class="text-muted mt-2 fw-semibold mb-0">Catégories d'ouvrages</p>
					</div>
				</div>
			</div>

			{# Livres #}
			<div class="col-sm-6 col-lg-4">
				<div class="card dashboard-card bg-body text-body shadow-sm border-0 border-start border-4 border-warning h-100">
					<div class="card-body text-center p-4">
						<i class="fa fa-book fa-3x text-warning mb-3"></i>
						<h2 class="display-5 fw-bold mb-0 text-warning">{{ nbLivres }}</h2>
						<p class="text-muted mt-2 fw-semibold mb-0">Livres au catalogue</p>
					</div>
				</div>
			</div>

			{# Emprunts #}
			<div class="col-sm-6 col-lg-4">
				<div class="card dashboard-card bg-body text-body shadow-sm border-0 border-start border-4 border-secondary h-100">
					<div class="card-body text-center p-4">
						<i class="fa fa-handshake fa-3x text-secondary mb-3"></i>
						<h2 class="display-5 fw-bold mb-0 text-secondary">{{ nbEmprunts }}</h2>
						<p class="text-muted mt-2 fw-semibold mb-0">Emprunts totaux</p>
					</div>
				</div>
			</div>

			{# Réservations #}
			<div class="col-sm-6 col-lg-4">
				<div class="card dashboard-card bg-body text-body shadow-sm border-0 border-start border-4 border-danger h-100">
					<div class="card-body text-center p-4">
						<i class="fa fa-calendar-check fa-3x text-danger mb-3"></i>
						<h2 class="display-5 fw-bold mb-0 text-danger">{{ nbReservations }}</h2>
						<p class="text-muted mt-2 fw-semibold mb-0">Réservations en attente</p>
					</div>
				</div>
			</div>

		</div>

		{% if is_granted('ROLE_ADMIN') %}
			<div class="row mt-5 mb-4">
				<div class="col-12 text-center">
					<a href="{{ path('admin_statistiques') }}" class="btn btn-outline-primary btn-lg rounded-pill shadow-sm px-4">
						<i class="fa fa-chart-pie me-2"></i>
						Accéder aux statistiques détaillées
					</a>
				</div>
			</div>
		{% endif %}
	</div>
{% endblock %}
