{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Emprunts de
	{{ adherent.utilisateur.prenom }}
	{{ adherent.utilisateur.nom }}
{% endblock %}

{% block content_header %}
	<div>
		<a href="{{ urlRetour }}" class="btn btn-secondary mb-3">
			<i class="fa fa-arrow-left me-1"></i>
			Retour à la liste
		</a>
		<h1>
			<i class="fa fa-book me-2"></i>Emprunts de
			{{ adherent.utilisateur.prenom }}
			{{ adherent.utilisateur.nom }}
		</h1>
	</div>
{% endblock %}

{% block main %}
	<div class="container mt-4">
		<div class="card mb-4">
			<div class="card-body">
				<div class="row">
					<div class="col-md-4">
						<strong>Email :</strong>
						{{ adherent.utilisateur.email }}
					</div>
					<div class="col-md-4">
						<strong>Téléphone :</strong>
						{{ adherent.numTel }}
					</div>
					<div class="col-md-4">
						<strong>Date de naissance :</strong>
						{{ adherent.dateNaiss|date('d/m/Y') }}
					</div>
					<div class="col-md-4">
						<strong>Date d'adhésion :</strong>
						{{ adherent.dateAdhesion|date('d/m/Y') }}
					</div>
					<div class="col-md-4">
						<strong>Adresse postale :</strong>
						{{ adherent.adressePostale }}
					</div>
					<div class="col-md-4 mt-3">
						<strong>Statut du compte :</strong>
						{% if adherent.estActif %}
							<span class="badge bg-success">Actif</span>
						{% else %}
							<span class="badge bg-danger">Suspendu</span>
						{% endif %}
					</div>
				</div>
			</div>
		</div>

		{# Flash messages #}
		{% for type, messages in app.flashes %}
			{% for message in messages %}
				<div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
					{{ message }}
					<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
				</div>
			{% endfor %}
		{% endfor %}

		{# Action buttons #}
		<div class="mb-4 d-flex gap-2">
			<a href="{{ ea_url() .setController('App\\Controller\\Admin\\EmpruntCrudController') .setAction('new') .unset('entityId') .set('adherentId', adherent.idAdh) }}" class="btn btn-primary">
				<i class="fa fa-plus me-1"></i>
				Enregistrer un emprunt
			</a>

			<a href="{{ ea_url() .setController('App\\Controller\\Admin\\AdherentCrudController') .setAction('toggleActif') .set('entityId', adherent.idAdh) }}" class="btn {% if adherent.estActif %}btn-outline-danger{% else %}btn-outline-success{% endif %}" onclick="return confirm('Êtes-vous sûr de vouloir {% if adherent.estActif %}suspendre{% else %}réactiver{% endif %} ce compte ?');">

				{% if adherent.estActif %}
					<i class="fa fa-ban me-1"></i>
					Suspendre le compte
				{% else %}
					<i class="fa fa-check-circle me-1"></i>
					Réactiver le compte
				{% endif %}
			</a>
		</div>

		{# Tableau des emprunts en cours #}
		<h4 class="mt-3 mb-3">
			<i class="fa fa-clock me-2"></i>Emprunts en cours</h4>
		{% set empruntsEnCours = emprunts|filter(e => e.dateRetourReel is null) %}
		{% if empruntsEnCours|length > 0 %}
			<div class="table-responsive mb-4">
				<table class="table table-striped table-hover">
					<thead class="table-dark">
						<tr>
							<th>Livre</th>
							<th>Date d'emprunt</th>
							<th>Date retour prévue</th>
							<th>Statut</th>
							<th>Action</th>
						</tr>
					</thead>
					<tbody>
						{% for emprunt in empruntsEnCours %}
							<tr>
								<td>{{ emprunt.livre }}</td>
								<td>{{ emprunt.dateEmprunt|date('d/m/Y') }}</td>
								<td>{{ emprunt.dateRetour|date('d/m/Y') }}</td>
								<td>
									{% if emprunt.enRetard %}
										<span class="badge badge-retard">En retard</span>
									{% else %}
										<span class="badge badge-en-cours">En cours</span>
									{% endif %}
								</td>
								<td>
									<a href="{{ ea_url() .setController('App\\Controller\\Admin\\AdherentCrudController') .setAction('marquerRendu') .set('empruntId', emprunt.idEmp) }}" class="btn btn-sm btn-success" onclick="return confirm('Confirmer le retour de ce livre ?')">
										<i class="fa fa-check me-1"></i>
										Marquer comme rendu
									</a>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% else %}
			<div class="alert alert-info mb-4">
				<i class="fa fa-info-circle me-1"></i>
				Aucun emprunt en cours.
			</div>
		{% endif %}

		{# Tableau des emprunts terminés #}
		<h4 class="mb-3">
			<i class="fa fa-check-circle me-2"></i>Emprunts terminés</h4>
		{% set empruntsTermines = emprunts|filter(e => e.dateRetourReel is not null) %}
		{% if empruntsTermines|length > 0 %}
			<div class="table-responsive">
				<table class="table table-striped table-hover">
					<thead class="table-dark">
						<tr>
							<th>Livre</th>
							<th>Date d'emprunt</th>
							<th>Date retour effectif</th>
						</tr>
					</thead>
					<tbody>
						{% for emprunt in empruntsTermines %}
							<tr>
								<td>{{ emprunt.livre }}</td>
								<td>{{ emprunt.dateEmprunt|date('d/m/Y') }}</td>
								<td>{{ emprunt.dateRetourReel|date('d/m/Y') }}</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% else %}
			<div class="alert alert-info">
				<i class="fa fa-info-circle me-1"></i>
				Aucun emprunt terminé.
			</div>
		{% endif %}
	</div>
{% endblock %}
