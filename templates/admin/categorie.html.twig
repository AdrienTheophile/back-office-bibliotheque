{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Catégorie :
	{{ categorie.nom }}
{% endblock %}

{% block content_header %}
	<div>
		<a href="{{ urlRetour }}" class="btn btn-secondary mb-3">
			<i class="fa fa-arrow-left me-1"></i>
			Retour à la liste
		</a>
		<h1>
			<i class="fa fa-tags me-2"></i>Catégorie :
			{{ categorie.nom }}
		</h1>
	</div>
{% endblock %}

{% block main %}
	<div class="container mt-4">
		<div class="card mb-4">
			<div class="card-body">
				<p>
					<strong>Description :</strong>
				</p>
				<p>{{ categorie.description }}</p>
			</div>
		</div>

		{# Bouton pour ajouter un livre à cette catégorie #}
		<div class="mb-4">
			<a href="{{ ea_url() .setController('App\\Controller\\Admin\\LivreCrudController') .setAction('new') .unset('entityId') .set('categorieId', categorie.idCat) }}" class="btn btn-primary">
				<i class="fa fa-plus me-1"></i>
				Ajouter un livre à cette catégorie
			</a>
		</div>

		{# Tableau des livres de cette catégorie #}
		<h4 class="mt-3 mb-3">
			<i class="fa fa-book me-2"></i>Livres dans cette catégorie ({{ livres|length }})
		</h4>

		{% if livres|length > 0 %}
			<div class="table-responsive mb-4">
				<table class="table table-striped table-hover">
					<thead class="table-dark">
						<tr>
							<th>Titre</th>
							<th>Langue</th>
							<th>Date de sortie</th>
							<th>Disponibilité</th>
						</tr>
					</thead>
					<tbody>
						{% for livre in livres %}
							<tr>
								<td>{{ livre.titre }}</td>
								<td>{{ livre.langue }}</td>
								<td>{{ livre.dateSortie ? livre.dateSortie|date('d/m/Y') : '-' }}</td>
								<td>
									{% if livre.disponible %}
										<span class="badge badge-success" style="background-color: green;">Disponible</span>
									{% else %}
										<span class="badge badge-warning" style="background-color: orange;">Indisponible</span>
									{% endif %}
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% else %}
			<div class="alert alert-info mb-4">
				<i class="fa fa-info-circle me-1"></i>
				Aucun livre dans cette catégorie pour le moment.
			</div>
		{% endif %}
	</div>
{% endblock %}
